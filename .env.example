# Public read-only access works without any env vars —
# the compiled binary defaults to https://api.releases.sh.

# Override the API host (useful for staging or self-hosted instances).
# RELEASED_API_URL=https://api.releases.sh

# Required for admin operations (write endpoints).
# RELEASED_API_KEY=

# Opt out of anonymous usage telemetry.
# RELEASED_TELEMETRY_DISABLED=1
